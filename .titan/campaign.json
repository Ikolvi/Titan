{
  "$schema": "titan://campaign/v1",
  "name": "questboard_full_regression",
  "description": "Full regression campaign for Questboard app: critical paths + all Gauntlet edge cases from 5 recorded sessions",
  "tags": ["regression", "gauntlet", "full-coverage"],
  "failurePolicy": "continueAll",
  "timeout": 600000,
  "includeGauntlet": false,
  "entries": [
    {
      "stratagem": {
        "$schema": "titan://stratagem/v1",
        "name": "critical_path_quest_lifecycle",
        "description": "Home → Quest Detail → Quest Edit → back to detail → back to home (core CRUD flow)",
        "tags": ["critical-path", "navigation", "quest"],
        "startRoute": "/",
        "timeout": 60000,
        "failurePolicy": "abortOnFirst",
        "steps": [
          {
            "id": 1,
            "action": "verify",
            "description": "Verify Home screen loaded",
            "expectations": {
              "route": "/",
              "elementsPresent": [{"label": "View Quest"}],
              "settleTimeout": 3000
            }
          },
          {
            "id": 2,
            "action": "tap",
            "description": "Tap View Quest to open quest detail",
            "target": {"label": "View Quest"},
            "waitAfter": 1000,
            "expectations": {
              "route": "/quest/:id"
            }
          },
          {
            "id": 3,
            "action": "verify",
            "description": "Verify Quest Detail loaded",
            "expectations": {
              "elementsPresent": [{"label": "Edit"}],
              "settleTimeout": 2000
            }
          },
          {
            "id": 4,
            "action": "tap",
            "description": "Tap Edit to open quest editor",
            "target": {"label": "Edit"},
            "waitAfter": 1000,
            "expectations": {
              "route": "/quest/:id/edit"
            }
          },
          {
            "id": 5,
            "action": "verify",
            "description": "Verify Quest Edit screen loaded",
            "expectations": {
              "settleTimeout": 2000
            }
          },
          {
            "id": 6,
            "action": "back",
            "description": "Navigate back to Quest Detail",
            "waitAfter": 1000,
            "expectations": {
              "route": "/quest/:id",
              "elementsPresent": [{"label": "Edit"}]
            }
          },
          {
            "id": 7,
            "action": "back",
            "description": "Navigate back to Home",
            "waitAfter": 1000,
            "expectations": {
              "route": "/",
              "elementsPresent": [{"label": "View Quest"}]
            }
          }
        ]
      },
      "dependsOn": []
    },
    {
      "stratagem": {
        "$schema": "titan://stratagem/v1",
        "name": "critical_path_settings_roundtrip",
        "description": "Home → Settings → back to Home (verify state preservation)",
        "tags": ["critical-path", "navigation", "settings"],
        "startRoute": "/",
        "timeout": 30000,
        "failurePolicy": "abortOnFirst",
        "steps": [
          {
            "id": 1,
            "action": "tap",
            "description": "Tap Settings",
            "target": {"label": "Settings"},
            "waitAfter": 1000,
            "expectations": {
              "route": "/settings"
            }
          },
          {
            "id": 2,
            "action": "verify",
            "description": "Verify Settings screen loaded",
            "expectations": {
              "settleTimeout": 2000
            }
          },
          {
            "id": 3,
            "action": "back",
            "description": "Navigate back to Home",
            "waitAfter": 1000,
            "expectations": {
              "route": "/",
              "elementsPresent": [{"label": "View Quest"}, {"label": "Settings"}]
            }
          }
        ]
      },
      "dependsOn": ["critical_path_quest_lifecycle"]
    },
    {
      "stratagem": {
        "$schema": "titan://stratagem/v1",
        "name": "critical_path_all_screens_reachable",
        "description": "Visit every screen from Home to verify all navigation links work",
        "tags": ["critical-path", "navigation", "smoke"],
        "startRoute": "/",
        "timeout": 60000,
        "failurePolicy": "continueAll",
        "steps": [
          {
            "id": 1,
            "action": "tap",
            "description": "Navigate to Shade Demo",
            "target": {"label": "Shade Demo"},
            "waitAfter": 1000,
            "expectations": {"route": "/shade-demo"}
          },
          {
            "id": 2,
            "action": "back",
            "description": "Back to Home",
            "waitAfter": 500
          },
          {
            "id": 3,
            "action": "tap",
            "description": "Navigate to Enterprise",
            "target": {"label": "Enterprise"},
            "waitAfter": 1000,
            "expectations": {"route": "/enterprise"}
          },
          {
            "id": 4,
            "action": "back",
            "description": "Back to Home",
            "waitAfter": 500
          },
          {
            "id": 5,
            "action": "tap",
            "description": "Navigate to Forms (dead end screen)",
            "target": {"label": "Forms"},
            "waitAfter": 1000,
            "expectations": {"route": "/form-demo"}
          },
          {
            "id": 6,
            "action": "back",
            "description": "Back from dead-end Form Demo",
            "waitAfter": 1000,
            "expectations": {
              "route": "/",
              "settleTimeout": 3000
            }
          }
        ]
      },
      "dependsOn": ["critical_path_quest_lifecycle"]
    },
    {
      "stratagem": {
        "$schema": "titan://stratagem/v1",
        "name": "dead_end_form_demo_back",
        "description": "Navigate to the /form-demo dead end and verify back button works correctly",
        "tags": ["dead-end", "edge-case", "form-demo"],
        "startRoute": "/",
        "timeout": 30000,
        "failurePolicy": "continueAll",
        "steps": [
          {
            "id": 1,
            "action": "tap",
            "description": "Navigate to Form Demo",
            "target": {"label": "Forms"},
            "waitAfter": 1000,
            "expectations": {"route": "/form-demo"}
