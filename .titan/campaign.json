            "id": 2,
            "action": "back",
            "description": "Press back from dead-end screen",
            "waitAfter": 1000,
            "expectations": {
              "route": "/",
              "settleTimeout": 3000
            }
          },
          {
            "id": 3,
            "action": "verify",
            "description": "Verify Home is intact after dead-end return",
            "expectations": {
              "elementsPresent": [{"label": "View Quest"}, {"label": "Settings"}, {"label": "Forms"}]
            }
          }
        ]
      },
      "dependsOn": []
    },
    {
      "stratagem": {
